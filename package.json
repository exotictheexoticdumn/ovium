{
  "name": "ovium",
  "private": true,
  "version": "0.0.1",
  "description": "Code-first 3D model ecosystem by Erox",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "validate": "pnpm --filter @ovium/cli run start -- validate",
    "build-catalog": "pnpm --filter @ovium/cli run start -- build-catalog"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ]
}
