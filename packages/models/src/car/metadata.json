{
  "name": "Car",
  "importName": "createCar",
  "category": "vehicles",
  "tags": ["car", "buggy", "off-road", "drivable", "low-poly"],
  "version": "0.1.0",
  "thumbnail": "car.png",
  "description": "A low-poly off-road buggy with an exposed roll cage, coilover suspension, and drivable physics-lite behavior.",
  "editableProps": {
    "frame.frameColor": { "type": "color", "default": "#e8571f", "description": "Roll cage tube color" },
    "frame.panelColor": { "type": "color", "default": "#f2f2f2", "description": "Nose/rear panel color" },
    "wheels.color": { "type": "color", "default": "#161616" },
    "wheels.rimColor": { "type": "color", "default": "#8a8a8a" },
    "wheels.radius": { "type": "number", "default": 0.52 },
    "suspension.shockColor": { "type": "color", "default": "#2b2b2b" },
    "suspension.coilColor": { "type": "color", "default": "#c94f1f" },
    "lights.on": { "type": "boolean", "default": true },
    "lights.color": { "type": "color", "default": "#fff4d6" },
    "interior.seatColor": { "type": "color", "default": "#8a6a4a" },
    "interior.wheelColor": { "type": "color", "default": "#1a1a1a" }
  },
  "animations": ["toggleLights", "drive", "enableTerrainFollow"]
}
